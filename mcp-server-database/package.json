    "pg": "^8.11.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
