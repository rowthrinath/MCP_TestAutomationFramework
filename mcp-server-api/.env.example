# Bearer Token Configuration
# Copy this file to .env and add your actual tokens

# Default bearer token (used when no token is specified)
BEARER_TOKEN=your_actual_bearer_token_here

# Environment-specific tokens (optional)
BEARER_TOKEN_DEV=dev_token_xyz123
BEARER_TOKEN_STAGING=staging_token_abc456
BEARER_TOKEN_PROD=prod_token_def789

# API Configuration
API_BASE_URL=https://api.example.com
API_TIMEOUT=30000

# Proxy settings (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# Debug mode (optional)
# DEBUG=true
